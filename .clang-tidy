# clang-tidy 配置
# 用法: clang-tidy -p build --config-file=.clang-tidy rpckit/network/tcp_connection.cpp
# 并行: find rpckit common -name "*.cpp" | xargs -P8 -I{} clang-tidy -p build --config-file=.clang-tidy {}

Checks: >
  -*,
  readability-identifier-naming,
  readability-braces-around-statements,
  modernize-use-nullptr,
  modernize-use-override,
  modernize-pass-by-value,
  modernize-use-using,
  modernize-redundant-void-arg,
  bugprone-use-after-move,
  cert-err34-c,
  cert-err52-cpp,
  performance-for-range-copy,
  performance-unnecessary-copy-initialization,
  -google-build-using-namespace

CheckOptions:
  # 函数名：PascalCase
  - key: readability-identifier-naming.FunctionCase
    value: CamelCase
  # 类/结构/枚举：PascalCase
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.StructCase
    value: CamelCase
  - key: readability-identifier-naming.EnumCase
    value: CamelCase
  - key: readability-identifier-naming.EnumConstantCase
    value: CamelCase
  # 私有成员：m_ 前缀 + snake_case
  - key: readability-identifier-naming.PrivateMemberPrefix
    value: 'm_'
  - key: readability-identifier-naming.PrivateMemberCase
    value: lower_case
  # 公有成员/局部变量/参数：snake_case
  - key: readability-identifier-naming.PublicMemberCase
    value: lower_case
  - key: readability-identifier-naming.VariableCase
    value: lower_case
  - key: readability-identifier-naming.ParameterCase
    value: lower_case
  # 命名空间：lower_case
  - key: readability-identifier-naming.NamespaceCase
    value: lower_case
  # 宏：UPPER_CASE
  - key: readability-identifier-naming.MacroCase
    value: UPPER_CASE
  # typedef/using：PascalCase
  - key: readability-identifier-naming.TypedefCase
    value: CamelCase
